/**
 * @fileoverview Firestore Security Rules for Resume App
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and resumes,
 * while allowing public read access to templates and shared resumes.
 *
 * Data Structure:
 * - /users/{userId}: User profile information.
 * - /users/{userId}/resumes/{resumeId}: Resumes owned by a specific user.
 * - /templates/{templateId}: Globally available resume templates.
 * - /publicResumes/{shareId}: Publicly shared resumes.
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Feedback for shared resumes.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profiles and resumes.
 * - Templates are publicly readable but not writable by clients.
 * - Publicly shared resumes are readable by anyone, but only the owner can modify them.
 * - Listing of documents is enabled only for user's own resumes for now.
 *
 * Denormalization for Authorization:
 * - Resumes have a `userId` field that must match the document path to enforce ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user profiles. Users can only read and write their own profile.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' creates their profile.
     * @deny (create) User with ID 'user123' tries to create profile for 'user456'.
     * @allow (get) User with ID 'user123' reads their own profile.
     * @deny (get) User with ID 'user123' tries to read profile of 'user456'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      allow create: if isOwner(userId);
      allow get: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
      allow list: if false;
    }

    /**
     * @description Enforces access control for resumes. Users can only read and write their own resumes.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) User with ID 'user123' creates a resume under their profile.
     * @deny (create) User with ID 'user123' tries to create a resume under 'user456' profile.
     * @allow (get) User with ID 'user123' reads their own resume.
     * @deny (get) User with ID 'user123' tries to read resume of 'user456'.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/resumes/{resumeId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      allow create: if isOwner(userId);
      allow get: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
      allow list: if isOwner(userId);
    }

    /**
     * @description Allows public read access to resume templates.
     * @path /templates/{templateId}
     * @allow (get) Any user can read a template.
     * @deny (create) No user can create templates through the client.
     * @principle Allows public read access while restricting writes.
     */
    match /templates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public read access to publicly shared resumes, but only the owner can modify them.
     * @path /publicResumes/{shareId}
     * @allow (get) Any user can read a public resume.
     * @deny (create) Users cannot directly create documents in publicResumes; they must share an existing resume.
     * @principle Public read with owner-only writes.
     */
    match /publicResumes/{shareId} {
       allow get: if true;
       allow list: if true;
      // CRITICAL: Cannot implement owner-only writes. The 'Resume' entity is missing an 'ownerId' or 'authorId' field.
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn();
      allow delete: if false;
    }

    /**
     * @description Allows anyone to create feedback for public resumes.
     * @path /publicResumes/{shareId}/feedback/{feedbackId}
     * @allow (create) Any user can submit feedback for a public resume.
     * @deny (update) No user can update existing feedback.
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
      allow create: if true;
      allow get: if true;
      allow update: if false;
      allow delete: if false;
      allow list: if true;
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }
}