/**
 * @file Firestore Security Rules
 * @core-philosophy This ruleset enforces a strict user-ownership model for user profiles and resumes.
 *  Templates are publicly readable. Public Resumes are publicly readable, but only feedback can be added.
 * @data-structure
 *  - /users/{userId}: Stores user profiles.
 *  - /users/{userId}/resumes/{resumeId}: Stores resumes owned by a specific user.
 *  - /templates/{templateId}: Stores resume templates (globally accessible).
 *  - /publicResumes/{shareId}: Stores publicly shared resumes
 *  - /publicResumes/{shareId}/feedback/{feedbackId}: Stores feedback for shared resumes
 * @key-security-decisions
 *  - Users can only access their own profiles and resumes.
 *  - Templates are publicly readable.
 *  - Listing of all users is disallowed.
 *  - Public Resumes are publicly readable
 * @denormalization-for-authorization No denormalization is needed as path-based ownership is used for users and resumes.
 * @structural-segregation Public resumes and their feedback are stored in a separate collection to allow for public read access without compromising user data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure user profiles. Users can only read/write their own profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creates their own profile with matching userId.
     * @allow (get, update, delete) - Authenticated user accesses their own profile.
     * @deny (create) - Authenticated user attempts to create a profile with a mismatched userId.
     * @deny (list) - Listing all users is not allowed.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.email is string;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secure resumes. Users can only read/write their own resumes.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) - Authenticated user creates a resume under their own userId.
     * @allow (get, update, delete) - Authenticated user accesses their own resume.
     * @deny (create) - Authenticated user attempts to create a resume under a different userId.
     * @deny (list) - Authenticated user lists resumes under their own userId.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/resumes/{resumeId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Templates are publicly readable.
     * @path /templates/{templateId}
     * @allow (get, list) - Any user can read templates.
     * @deny (create, update, delete) - No one can create, update, or delete templates.
     * @principle Allows public read access to templates.
     */
    match /templates/{templateId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

        /**
         * @description Public resumes are publicly readable.
         * @path /publicResumes/{shareId}
         * @allow (get, list) - Any user can read public resumes.
         * @deny (create, update, delete) - No one can create, update, or delete public resumes directly.
         */
        match /publicResumes/{shareId} {
            allow get, list: if true;
            allow create, update, delete: if false;
        }

        /**
         * @description Feedback for public resumes is publicly writable and readable.
         * @path /publicResumes/{shareId}/feedback/{feedbackId}
         * @allow (create, get, list) - Any user can give feedback.
         * @deny (update, delete) - No one can update or delete existing feedback.
         */
        match /publicResumes/{shareId}/feedback/{feedbackId} {
            allow create, get, list: if true;
            allow update, delete: if false;
        }
  }
}