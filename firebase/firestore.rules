rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profiles.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile.
     * @allow (get) User with ID 'user123' can read their profile.
     * @allow (update) User with ID 'user123' can update their profile.
     * @allow (delete) User with ID 'user123' can delete their profile.
     * @deny (create) User with ID 'user456' cannot create a profile for 'user123'.
     * @deny (get) User with ID 'user456' cannot read profile of 'user123'.
     * @deny (update) User with ID 'user456' cannot update profile of 'user123'.
     * @deny (delete) User with ID 'user456' cannot delete profile of 'user123'.
     * @principle Enforces document ownership for writes; users can only manage their own profiles.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted.
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Manages resumes belonging to a specific user.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) User with ID 'user123' can create a resume under their profile.
     * @allow (get) User with ID 'user123' can read a resume under their profile.
     * @allow (update) User with ID 'user123' can update a resume under their profile.
     * @allow (delete) User with ID 'user123' can delete a resume under their profile.
     * @deny (create) User with ID 'user456' cannot create a resume for user 'user123'.
     * @deny (get) User with ID 'user456' cannot read a resume belonging to user 'user123'.
     * @deny (update) User with ID 'user456' cannot update a resume belonging to user 'user123'.
     * @deny (delete) User with ID 'user456' cannot delete a resume belonging to user 'user123'.
     * @principle Enforces path-based ownership for resumes within a user's data tree.
     */
    match /users/{userId}/resumes/{resumeId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages resume templates, which are publicly accessible.
     * @path /templates/{templateId}
     * @allow (get) Any user, authenticated or not, can read templates.
     * @allow (list) Any user, authenticated or not, can list templates.
     * @deny (create) No user can create templates via client.
     * @deny (update) No user can update templates via client.
     * @deny (delete) No user can delete templates via client.
     * @principle Templates are read-only for all users; write operations are prohibited from the client.
     */
    match /templates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages publicly shared resumes.
     * @path /publicResumes/{shareId}
     * @allow (get) Any user, authenticated or not, can read a shared resume.
     * @allow (list) Any user, authenticated or not, can list shared resumes.
     * @deny (create) No user can create a shared resume via this path directly.
     * @deny (update) No user can update a shared resume via this path directly.
     * @deny (delete) No user can delete a shared resume via this path directly.
     * @principle Shared resumes are read-only for all users; write operations are prohibited from the client on this path.
     */
    match /publicResumes/{shareId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages feedback for publicly shared resumes.
     * @path /publicResumes/{shareId}/feedback/{feedbackId}
     * @allow (get) Any user, authenticated or not, can read feedback.
     * @allow (list) Any user, authenticated or not, can list feedback.
     * @allow (create) Any user, authenticated or not, can create feedback.
     * @deny (update) No user can update existing feedback.
     * @deny (delete) No user can delete feedback.
     * @principle Feedback is publicly readable and writable on creation, but updates and deletions are prohibited.
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
      allow get: if true;
      allow list: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }
  }
}