/**
 * @fileoverview Firestore Security Rules for Resume App
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and resumes,
 * while allowing public read access to resume templates and shared resumes.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data. Each user can only access their own profile.
 * - /users/{userId}/resumes/{resumeId}: Stores resume data. Each user can only access their own resumes.
 * - /templates/{templateId}: Stores resume templates. These are publicly readable.
 * - /publicResumes/{shareId}: Stores publicly shared resumes. These are publicly readable.
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Stores feedback for shared resumes.
 *
 * Key Security Decisions:
 * - Users can only create, read, update, and delete their own profiles and resumes.
 * - Resume templates are publicly readable but not writable via the client.
 * - Shared resumes are publicly readable, but feedback requires existence.
 *
 * Denormalization for Authorization:
 * - The `Resume` entity includes a `userId` field, denormalizing the user-resume relationship.
 * This allows rules to quickly verify ownership without additional `get()` calls.
 *
 * Structural Segregation:
 * - Private user resumes are stored under `/users/{userId}/resumes/{resumeId}`, while public shared
 * resumes are stored under `/publicResumes/{shareId}`. This separation ensures that private resumes
 * are not accidentally exposed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (create) - Authenticated user can create their own profile if the userId matches their auth.uid.
     * @allow (get, update, delete) - Authenticated user can only access their own profile.
     * @deny (create) - User cannot create a profile with a different userId.
     * @deny (get, update, delete) - User cannot access another user's profile.
     * @principle Enforces strict user-ownership for profiles.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }
        
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.email == request.auth.token.email;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to resumes belonging to a user.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) - Authenticated user can create a resume under their userId.
     * @allow (get, list, update, delete) - Authenticated user can only access their own resumes.
     * @deny (create) - User cannot create a resume under another user's userId.
     * @deny (get, list, update, delete) - User cannot access another user's resumes.
     * @principle Enforces strict user-ownership for resumes.
     */
    match /users/{userId}/resumes/{resumeId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to resume templates.
     * @path /templates/{templateId}
     * @allow (get, list) - All users can read templates.
     * @deny (create, update, delete) - Templates can only be managed by admins (not implemented in this ruleset).
     * @principle Allows public read access to resume templates.
     */
    match /templates/{templateId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to public, shareable resumes.
     * @path /publicResumes/{shareId}
     * @allow (get, list) - All users can read shared resumes.
     * @deny (create, update, delete) - Shared resumes can only be managed via backend functions (not implemented in this ruleset).
     * @principle Allows public read access to shared resumes.
     */
    match /publicResumes/{shareId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to feedback for public, shareable resumes.
     * @path /publicResumes/{shareId}/feedback/{feedbackId}
     * @allow (create) - Any signed in user can create feedback.
     * @deny (get, list, update, delete) - Not implemented.
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
       function isSignedIn() {
        return request.auth != null;
      }
      allow create: if isSignedIn();
      allow get, list, update, delete: if false;
    }
  }
}