/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles and resumes.
 * Templates are publicly accessible. Public resumes are publicly readable but owner-writable.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, owned by the corresponding user.
 * - /users/{userId}/resumes/{resumeId}: Resumes, owned by the user specified in the path.
 * - /templates/{templateId}: Resume templates, publicly accessible.
 * - /publicResumes/{shareId}: Publicly shared resumes.
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Feedback on shared resumes.
 *
 * Key Security Decisions:
 * - Users can only read/write their own profiles.
 * - Users can only read/write their own resumes (nested under their profile).
 * - Templates are publicly readable but not writable.
 * - Public resumes are publicly readable, but only the owner can modify or delete.
 * - Anyone can create feedback on public resumes.
 *
 * Denormalization for Authorization:
 * - Resumes denormalize the `userId` to enable ownership checks within the /users/{userId}/resumes/{resumeId} path.
 *
 * Structural Segregation:
 * - Private resumes are stored under /users/{userId}/resumes/{resumeId}, while public resumes are stored under /publicResumes/{shareId}. This separation prevents the need for complex boolean checks on list operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) User with matching UID can create their own profile.
     * @allow (get, update, delete) User with matching UID can read/update/delete their own profile.
     * @deny (create, get, update, delete) Any other user cannot access another user's profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.email == request.auth.token.email;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Controls access to resume documents nested under a user profile.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) User with matching UID can create resumes under their profile.
     * @allow (get, update, delete) User with matching UID can read/update/delete their own resumes.
     * @deny (create, get, update, delete) Any other user cannot access another user's resumes.
     * @principle Enforces path-based ownership and prevents cross-user data access.
     */
    match /users/{userId}/resumes/{resumeId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Controls access to resume template documents.
     * @path /templates/{templateId}
     * @allow (get, list) All users can read templates.
     * @deny (create, update, delete) No users can create/update/delete templates through client SDKs.  These should be managed via the admin SDK.
     * @principle Allows public read access to templates while restricting write access.
     */
    match /templates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

      /**
       * @description Controls access to public resume documents.
       * @path /publicResumes/{shareId}
       * @allow (get, list) All users can read public resumes.
       * @allow (create) Owner with matching UID can create public resume.
       * @allow (update, delete) Owner with matching UID can update/delete their own public resumes.
       * @deny (create, update, delete) Any other user cannot access another user's resumes.
       * @principle Public read access with owner-only writes.
       */
    match /publicResumes/{shareId} {
        function isOwner(ownerId) {
            return request.auth != null && request.auth.uid == ownerId;
        }
        allow get: if true;
        allow list: if true;
        allow create: if request.auth.uid == request.resource.data.userId;
        allow update: if isOwner(resource.data.userId) && resource != null;
        allow delete: if isOwner(resource.data.userId) && resource != null;
    }

    /**
     * @description Controls access to feedback documents for public resumes.
     * @path /publicResumes/{shareId}/feedback/{feedbackId}
     * @allow (create) All users can submit feedback.
     * @allow (get, list) All users can view feedback.
     * @deny (update, delete) No user can update or delete existing feedback.
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
      allow get: if true;
      allow list: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }
  }
}