/**
 * @fileoverview Firestore Security Rules for Resume App
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and resumes,
 * while providing public read access to resume templates and shared resumes.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, accessible only to the owning user.
 * - /users/{userId}/resumes/{resumeId}: Resumes owned by a specific user, accessible only to that user.
 * - /templates/{templateId}: Publicly available resume templates.
 * - /publicResumes/{shareId}: Publicly shared resumes.
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Feedback on publicly shared resumes.
 *
 * Key Security Decisions:
 * - Users can only access their own profiles and resumes.
 * - Resume templates are publicly readable but not writable.
 * - Public resumes are publicly readable, but only the owner can modify them.
 * - Anyone can provide feedback on public resumes.
 *
 * Denormalization for Authorization:
 * - The `Resume` entity includes a `userId` field, enabling simple owner checks in security rules for resumes and their subcollections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description: Controls access to user profiles. Only the authenticated user can read and write their own profile.
     * @path: /users/{userId}
     * @allow: (get, update, delete) - Authenticated user with matching userId. (create) - Authenticated user can create their own profile if the userId matches their auth.uid.
     * @deny: (get, update, delete) - Any other user trying to access this profile. (create) - Any user creating a profile with a userId that doesn't match their own auth.uid.
     * @principle: Enforces strict user ownership for profile data.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description: Controls access to resumes. Only the owning user can create, read, update, and delete their resumes.
     * @path: /users/{userId}/resumes/{resumeId}
     * @allow: (create, get, update, delete) - Authenticated user with matching userId.
     * @deny: (create, get, update, delete) - Any other user trying to access these resumes.
     * @principle: Enforces strict user ownership for resume data.
     */
    match /users/{userId}/resumes/{resumeId} {
        function isOwner(userId) {
          return request.auth != null && request.auth.uid == userId;
        }

        allow get: if isOwner(userId);
        allow list: if false;
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
    }

    /**
     * @description: Controls access to resume templates. Templates are publicly readable.
     * @path: /templates/{templateId}
     * @allow: (get, list) - Any user can read templates.
     * @deny: (create, update, delete) - No user can create, update or delete templates through the client.
     * @principle: Templates are globally accessible for reading but are managed by the application.
     */
    match /templates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

      /**
       * @description: Controls access to publicly shared resumes.  Any user can read the resume. Only the owner can modify or delete it.
       * @path: /publicResumes/{shareId}
       * @allow: (get, list) - Any user can read shared resumes. (create, update, delete) - Only the original owner can modify.
       * @deny: (create, update, delete) - Other users cannot modify shared resumes.
       * @principle: Shared resumes are publicly readable but owner-modifiable.
       */
      match /publicResumes/{shareId} {
          allow get: if true;
          allow list: if true;

          // TODO: Add owner validation once the schema is updated with an ownership field.
          allow create: if request.auth != null;
          allow update: if request.auth != null; // TODO: Add owner validation once the schema is updated with an ownership field.
          allow delete: if request.auth != null; // TODO: Add owner validation once the schema is updated with an ownership field.
      }

      /**
       * @description: Controls access to feedback on public resumes. Any user can create feedback, and anyone can read it.
       * @path: /publicResumes/{shareId}/feedback/{feedbackId}
       * @allow: (get, list, create) - Any user can read and create feedback.
       * @deny: (update, delete) - No client-side updates or deletes of feedback.
       * @principle: Public feedback is allowed, but updates/deletes are not permitted.
       */
      match /publicResumes/{shareId}/feedback/{feedbackId} {
          allow get: if true;
          allow list: if true;
          allow create: if request.auth != null;
          allow update: if false;
          allow delete: if false;
      }
  }
}