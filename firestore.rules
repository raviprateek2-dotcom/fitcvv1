/**
 * @fileoverview Firestore Security Rules for Resume Builder Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes strong authorization controls while relaxing data validation to enable rapid prototyping. It uses a strict ownership model for user-specific data and allows public read access to templates.
 *
 * Data Structure:
 * - /users/{userId}: User profiles and settings.
 * - /users/{userId}/resumes/{resumeId}: Resumes owned by a specific user.
 * - /templates/{templateId}: Globally accessible resume templates.
 * - /publicResumes/{shareId}: Publicly shared resumes.
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Feedback on publicly shared resumes.
 *
 * Key Security Decisions:
 * - Users can only access their own profiles and resumes.
 * - Templates are publicly readable but not writable by clients.
 * - Listing of user profiles is disabled to prevent enumeration.
 * - Public resumes are readable by anyone.
 *
 * Denormalization for Authorization:
 * - Resumes are stored under /users/{userId}/resumes/{resumeId} to enforce path-based ownership.
 *
 * Structural Segregation:
 * - Public resumes are stored in a separate top-level collection (`/publicResumes/{shareId}`) to enable public read access without compromising the security of private resumes.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (create) User with matching ID can create their own profile.
     * @allow (get, update, delete) User with matching ID can access and modify their own profile.
     * @deny (create) User cannot create a profile with an ID that doesn't match their own.
     * @deny (get, update, delete) User cannot access or modify another user's profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to resumes owned by a specific user.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) User with matching ID can create a resume under their profile.
     * @allow (get, update, delete) User with matching ID can access and modify their own resume.
     * @deny (create) User cannot create a resume under another user's profile.
     * @deny (get, update, delete) User cannot access or modify another user's resume.
     * @principle Enforces document ownership and prevents cross-user data access.
     */
    match /users/{userId}/resumes/{resumeId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to resume templates. Templates are publicly readable, but cannot be created, updated, or deleted through the client.
     * @path /templates/{templateId}
     * @allow (get, list) Anyone can read templates.
     * @deny (create, update, delete) No client-side writes allowed.
     * @principle Provides public read access to shared template data.
     */
    match /templates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

      /**
       * @description Controls access to public resumes. Anyone can read public resumes, but write access is not enabled in this prototype.
       * @path /publicResumes/{shareId}
       * @allow (get, list) Anyone can read public resumes.
       * @deny (create, update, delete) No client-side writes allowed.
       * @principle Public read access for shared resumes.
       */
    match /publicResumes/{shareId} {
        allow get: if true;
        allow list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Controls access to feedback on public resumes. Public feedback is readable and creatable by anyone, but cannot be updated or deleted.
     * @path /publicResumes/{shareId}/feedback/{feedbackId}
     * @allow (get, list, create) Anyone can read and create feedback.
     * @deny (update, delete) No client-side updates or deletes allowed.
     * @principle Public read and create access for feedback on shared resumes.
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
        allow get: if true;
        allow list: if true;
        allow create: if true;
        allow update: if false;
        allow delete: if false;
    }
  }
}