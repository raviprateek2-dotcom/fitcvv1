/**
 * @fileOverview Firestore Security Rules for Resume App
 *
 * Core Philosophy:
 * This ruleset enforces a combination of user-based ownership and public read access with owner-controlled modification for resumes. User profiles are private. Templates are public read-only.
 *
 * Data Structure:
 * - `/users/{userId}`: Stores user profile information, accessible only to the user.
 * - `/users/{userId}/resumes/{resumeId}`: Stores a user's resumes, accessible only to the user.
 * - `/templates/{templateId}`: Stores resume templates, publicly readable.
 * - `/publicResumes/{shareId}`: Stores public copies of resumes that are publicly readable, but only the owner can modify.
 * - `/publicResumes/{shareId}/feedback/{feedbackId}`: Stores feedback for public resumes, open for all to create.
 *
 * Key Security Decisions:
 * - Users can only access their own profiles and resumes.
 * - Templates are publicly accessible (read-only).
 * - Public resumes are readable by anyone, but only the owner can modify them.
 * - Listing users or user resumes is disallowed.
 *
 * Denormalization for Authorization:
 * The `publicResumes` collection relies on the `userId` field within each document to enforce owner-only writes.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Defines the isSignedIn function.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the requesting user is the owner of the resource.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the requesting user is the owner of the resource and it exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces owner-only access to user profiles.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' can create their own profile at /users/user123.
     * @allow (get,update,delete) User with UID 'user123' can get, update, delete their own profile at /users/user123.
     * @deny (create) User with UID 'user456' cannot create a profile for user 'user123' at /users/user123.
     * @deny (get,update,delete) User with UID 'user456' cannot get, update, delete the profile of user 'user123' at /users/user123.
     * @principle Enforces user-based ownership for profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces owner-only access to resumes within a user's profile.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) User 'user123' can create a resume under their profile at /users/user123/resumes/resume1.
     * @allow (get,update,delete) User 'user123' can get, update, delete their resume at /users/user123/resumes/resume1.
     * @deny (create) User 'user456' cannot create a resume for user 'user123' at /users/user123/resumes/resume1.
     * @deny (get,update,delete) User 'user456' cannot get, update, delete the resume of user 'user123' at /users/user123/resumes/resume1.
     * @principle Enforces user-based ownership for resumes.
     */
    match /users/{userId}/resumes/{resumeId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read-only access to resume templates.
     * @path /templates/{templateId}
     * @allow (get,list) Any user, signed in or not, can retrieve template data.
     * @deny (create,update,delete) No user can create, update, or delete templates.
     * @principle Provides globally accessible resume templates.
     */
    match /templates/{templateId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to shared resumes, but restricts modifications to the owner.
     * @path /publicResumes/{shareId}
     * @allow (get,list) Any user can retrieve a shared resume.
     * @allow (create) User can create a shared resume if the userId matches the authenticated user's ID
     * @allow (update,delete) Only the owner (specified by the userId field) can modify or delete the shared resume.
     * @deny (create,update,delete) Other user cannot create, update, or delete shared resume.
     * @principle Provides public resume access with owner-controlled modification.
     */
    match /publicResumes/{shareId} {
      allow get, list: if true;
      allow create: if request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Allows anyone to create feedback for a shared resume.
     * @path /publicResumes/{shareId}/feedback/{feedbackId}
     * @allow (create) Any user can create feedback for a shared resume.
     * @deny (get,list,update,delete) No user can get, list, update, or delete feedback.
     * @principle Allows public feedback for shared resumes.
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}