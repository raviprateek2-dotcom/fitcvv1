/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a combination of ownership-based and public-read access control.
 *
 * Data Structure:
 * - /users/{userId}: User profile data, accessible only by the user.
 * - /users/{userId}/resumes/{resumeId}: Resumes owned by a specific user.
 * - /templates/{templateId}: Publicly accessible resume templates.
 * - /publicResumes/{shareId}: Publicly accessible resumes with limited write access.
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Feedback for public resumes.
 *
 * Key Security Decisions:
 * - User profiles are private and accessible only to the authenticated user.
 * - Users can only manage their own resumes.
 * - Resume Templates are publicly readable.
 * - Public Resumes are publicly readable, but only the owner can update or delete.
 * - Listing of documents in any collection is restricted to the document owner, unless the collection is entirely public.
 *
 * Denormalization for Authorization:
 * - The `Resume` entity includes a `userId` field to enable ownership checks without requiring additional `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile data.
     * @path /users/{userId}
     * @allow (get, list, create, update, delete) if the user is the owner of the profile.
     * @deny (get, list, create, update, delete) if the user is not the owner of the profile.
     * @principle Enforces document ownership for all operations on user profiles.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to user resumes.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (get, list, create, update, delete) if the user is the owner of the resume.
     * @deny (get, list, create, update, delete) if the user is not the owner of the resume.
     * @principle Enforces document ownership for all operations on user resumes.
     */
    match /users/{userId}/resumes/{resumeId} {
        function isOwner(userId) {
          return request.auth.uid == userId;
        }

        function isSignedIn() {
          return request.auth != null;
        }

        function isExistingOwner(userId) {
            return isSignedIn() && isOwner(userId);
        }

        allow get: if isSignedIn() && isOwner(userId);
        allow list: if false;
        allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isExistingOwner(userId) && request.resource.data.userId == userId;
    }

    /**
     * @description Controls access to resume templates.
     * @path /templates/{templateId}
     * @allow (get, list) to anyone.
     * @deny (create, update, delete) to everyone.
     * @principle Allows public read access to templates while restricting write access.
     */
    match /templates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

      /**
       * @description Controls access to public resumes.
       * @path /publicResumes/{shareId}
       * @allow get, list to anyone.
       * @allow create, update, delete only to the owner.
       * @principle Allows public read access to shared resumes, but restricts write access to the owner.
       */
      match /publicResumes/{shareId} {
          function isOwner() {
              return request.auth.uid == resource.data.userId;
          }

          function isSignedIn() {
              return request.auth != null;
          }

          function isExistingOwner() {
              return isSignedIn() && request.auth.uid == resource.data.userId;
          }

          allow get: if true;
          allow list: if true;
          allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
          allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
          allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      }

      /**
       * @description Controls access to feedback for public resumes.
       * @path /publicResumes/{shareId}/feedback/{feedbackId}
       * @allow get, list, create to anyone.
       * @deny update, delete to everyone.
       */
      match /publicResumes/{shareId}/feedback/{feedbackId} {
          allow get: if true;
          allow list: if true;
          allow create: if true;
          allow update: if false;
          allow delete: if false;
      }
  }
}