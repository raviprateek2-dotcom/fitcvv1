/**
 * @fileoverview Firestore Security Rules for Resume App
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and resumes
 * stored under their respective user IDs. Public resumes are readable by anyone,
 * but only updatable/deletable by the owner.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles.
 * - /users/{userId}/resumes/{resumeId}: Stores resumes owned by a specific user.
 * - /templates/{templateId}: Stores publicly accessible resume templates.
 * - /publicResumes/{shareId}: Stores publicly shared resumes.
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Stores feedback on publicly shared resumes.
 *
 * Key Security Decisions:
 * - User profiles and resumes are strictly owned by the user.
 * - Templates are publicly readable.
 * - Public resumes are readable by anyone, but only the owner can modify them.
 * - Listing of user profiles is disallowed.
 *
 * Denormalization for Authorization:
 * - Resumes store the userId to avoid needing to query the /users collection for ownership checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Restricts access to user profiles.
     * @path /users/{userId}
     * @allow (create) User can create their own profile if the userId matches their auth UID.
     * @allow (get) User can read their own profile if the userId matches their auth UID.
     * @allow (update) User can update their own profile if the userId matches their auth UID.
     * @allow (delete) User can delete their own profile if the userId matches their auth UID.
     * @deny (list) Listing all user profiles is prohibited.
     * @deny (create) User cannot create a profile for another user.
     * @deny (update) User cannot update another user's profile.
     * @deny (delete) User cannot delete another user's profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Restricts access to resumes nested under a user's profile.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) User can create a resume under their own profile.
     * @allow (get) User can read a resume under their own profile.
     * @allow (update) User can update a resume under their own profile.
     * @allow (delete) User can delete a resume under their own profile.
     * @deny (list) Only the owner can list their resumes.
     * @deny (create) User cannot create a resume under another user's profile.
     * @deny (update) User cannot update another user's resume.
     * @deny (delete) User cannot delete another user's resume.
     * @principle Enforces document ownership for all operations, and ensures data consistency between the path and document fields.
     */
    match /users/{userId}/resumes/{resumeId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isSignedIn() && isOwner(userId) && resource.data.userId == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to resume templates.
     * @path /templates/{templateId}
     * @allow (get, list) Templates are publicly readable.
     * @deny (create, update, delete) Templates can only be managed by administrators (currently not implemented).
     * @principle Allows public read access to resume templates.
     */
    match /templates/{templateId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

       /**
        * @description Allows public read access to shared resumes, but restricts write access to the owner.
        * @path /publicResumes/{shareId}
        * @allow (get, list) Shared resumes are publicly readable.
        * @allow (create) Allows a user to create a public resume if the userId field matches their auth UID.
        * @allow (update, delete) Only the owner of the shared resume can update or delete it.
        * @deny (create) A user cannot create a public resume for another user.
        * @deny (update) A user cannot update another user's public resume.
        * @deny (delete) A user cannot delete another user's public resume.
        * @principle Public read, owner-only write access.
        */
    match /publicResumes/{shareId} {
        function isSignedIn() {
            return request.auth != null;
        }

        function isOwner(userId) {
            return request.auth.uid == userId;
        }

        function isExistingOwner() {
            return isSignedIn() && isOwner(resource.data.userId);
        }

        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isExistingOwner();
        allow delete: if isExistingOwner();
    }

    /**
     * @description Restricts access to feedback on shared resumes.
     * @path /publicResumes/{shareId}/feedback/{feedbackId}
     * @allow (create) Allows anyone to create feedback on a public resume.
     * @allow (get, list) Allows anyone to read feedback on a public resume.
     * @deny (update, delete) Feedback cannot be updated or deleted (append-only).
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
        allow get, list, create: if true;
        allow update, delete: if false;
    }
  }
}