/**
 * @fileoverview Firestore Security Rules for Resume App.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and resumes,
 * while allowing public read access to templates and shared resumes.
 * User profiles and resumes are secured under the /users/{userId} path, ensuring
 * that only the authenticated user can access their own data. Templates are
 * globally readable, but write access is not granted in this prototype. Shared
 * resumes are publicly readable, and feedback can be added to them by anyone.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data.
 * - /users/{userId}/resumes/{resumeId}: Stores resumes owned by a specific user.
 * - /templates/{templateId}: Stores resume templates (globally readable).
 * - /publicResumes/{shareId}: Stores shared resume (publicly readable).
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Stores feedback for specific shared resume (publicly readable).
 *
 * Key Security Decisions:
 * - Users can only access their own profiles and resumes.
 * - Templates are publicly readable but not writable (in this prototype).
 * - Shared resumes are publicly readable.
 * - Anyone can add feedback to a shared resume.
 *
 * Denormalization for Authorization:
 * - The resume documents MUST contain a `userId` field that matches the ID in the `/users/{userId}` path to ensure authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) Authenticated user can create their own profile if the userId matches their auth UID.
     * @allow (get, list, update, delete) Authenticated user can only access their own profile.
     * @deny (create) If the userId does not match the authenticated user's UID.
     * @deny (update, delete) If the user does not exist.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId} {
      // function
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to resume documents under a user's profile.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) Authenticated user can create a resume under their profile if the userId matches their auth UID.
     * @allow (get, list, update, delete) Authenticated user can only access their own resumes.
     * @deny (create) If the userId does not match the authenticated user's UID.
     * @deny (update, delete) If the user does not exist.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId}/resumes/{resumeId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to template documents.
     * @path /templates/{templateId}
     * @allow (get, list) Anyone can read templates.
     * @deny (create, update, delete) No one can create, update, or delete templates (in this prototype).
     * @principle Templates are globally readable but not writable.
     */
    match /templates/{templateId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
      * @description Controls access to shared resume documents.
      * @path /publicResumes/{shareId}
      * @allow (get, list) Anyone can read public resumes.
      * @deny (create, update, delete) No one can create, update, or delete shared resumes.  Writes are not allowed for /publicResumes path.
      * @principle Public resumes are publicly readable but not writable.
      */
    match /publicResumes/{shareId} {
        allow get, list: if true;
        allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

      /**
       * @description Controls access to feedback documents for shared resumes.
       * @path /publicResumes/{shareId}/feedback/{feedbackId}
       * @allow (create) Anyone can submit feedback for a shared resume.
       * @allow (get, list) Anyone can read feedback for a shared resume.
       * @deny (update, delete) No one can update or delete feedback (in this prototype).
       * @principle Public feedback is allowed for shared resumes, but only creation is permitted.
       */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
        allow get, list, create: if true;
        allow update, delete: if false;
    }
  }
}