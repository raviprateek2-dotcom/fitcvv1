/**
 * @fileoverview Firestore Security Rules for Resume App
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for private user data,
 * allows public read access to shared resumes, and restricts write access
 * based on ownership and authentication.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles and preferences.
 * - /users/{userId}/resumes/{resumeId}: Stores a user's resumes.
 * - /templates/{templateId}: Stores publicly available resume templates.
 * - /publicResumes/{shareId}: Stores publicly shared resumes (copies of user resumes).
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Stores feedback for public resumes.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profiles and resumes.
 * - Templates are publicly readable but not writable by clients.
 * - Public resumes are publicly readable, but only the owner can update/delete them.
 * - Listing of user profiles is disallowed for privacy.
 *
 * Denormalization for Authorization:
 * - The `Resume` documents in the `/users/{userId}/resumes/{resumeId}` collection contain a `userId` field
 *   that is used to enforce ownership. This avoids needing to perform a `get()` request to the `/users/{userId}`
 *   document to verify ownership.
 * - The `publicResumes/{shareId}` documents are copies of user resumes, and they also contain a `userId` field
 *   for ownership verification of update and delete operations.
 *
 * Structural Segregation:
 * - Public resumes are stored in the `/publicResumes/{shareId}` collection, separate from the user's private
 *   resumes in `/users/{userId}/resumes/{resumeId}`. This allows for public read access to shared resumes
 *   without exposing private user data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the current user is signed in.
     * @example isSignedIn() == true if request.auth != null
     * @example isSignedIn() == false if request.auth == null
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the current user is the owner of the resource.
     * @param {string} userId - The user ID to compare against the request's authentication UID.
     * @return {bool} - True if the user is the owner, false otherwise.
     * @example isOwner("someUserId") == true if request.auth.uid == "someUserId"
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the current user is the owner of the resource and it exists.
     * @param {string} userId - The user ID to compare against the request's authentication UID.
     * @return {bool} - True if the user is the owner and resource exists, false otherwise.
     * @example isExistingOwner("someUserId") == true if request.auth.uid == "someUserId" && resource != null
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for user profiles. Only the authenticated user can read/write their own profile.
     * @path /users/{userId}
     * @allow (create) if request.auth.uid == "{userId}"
     * @allow (get) if request.auth.uid == "{userId}"
     * @allow (update) if request.auth.uid == "{userId}"
     * @allow (delete) if request.auth.uid == "{userId}"
     * @deny (create) if request.auth.uid != "{userId}"
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for resumes under a user profile. Only the owner can read/write their resumes.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) if request.auth.uid == "{userId}"
     * @allow (get) if request.auth.uid == "{userId}"
     * @allow (update) if request.auth.uid == "{userId}"
     * @allow (delete) if request.auth.uid == "{userId}"
     * @deny (create) if request.auth.uid != "{userId}"
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/resumes/{resumeId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for resume templates. Templates are publicly readable.
     * @path /templates/{templateId}
     * @allow (get) true
     */
    match /templates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for public resumes. Public resumes are publicly readable, but only the owner can update/delete.
     * @path /publicResumes/{shareId}
     * @allow (get) true
     * @allow (update, delete) if resource.data.userId == request.auth.uid.
     */
    match /publicResumes/{shareId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.resource.data.id == request.resource.data.shareId; //added id and shareId validation
      allow update: if isExistingOwner(request.resource.data.id);
      allow delete: if isExistingOwner(request.resource.data.id);
    }

    /**
     * @description Rules for feedback on public resumes. Anyone can leave feedback.
     * @path /publicResumes/{shareId}/feedback/{feedbackId}
     * @allow (create) true
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }
  }
}