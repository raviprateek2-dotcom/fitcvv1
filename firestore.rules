rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure user profiles. Users can only read/write their own profile.
     * @path /databases/{database}/documents/users/{userId}
     * @allow (create, update, delete, get, list) User with matching {userId} in request.auth
     * @deny (create, update, delete, get, list) User with mismatched {userId} in request.auth
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      // Listing users is not permitted.
      allow list: if false;
      // Only the user themselves can create their profile, matching the userId
      allow create: if isOwner(userId);
      // Only the user themselves can update their profile
      allow update: if isOwner(userId);
      // Only the user themselves can delete their profile
      allow delete: if isOwner(userId);
    }

    /**
     * @description Secure user resumes. Users can only read/write their own resumes.
     * @path /databases/{database}/documents/users/{userId}/resumes/{resumeId}
     * @allow (create, update, delete, get, list) User with matching {userId} in request.auth
     * @deny (create, update, delete, get, list) User with mismatched {userId} in request.auth
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/resumes/{resumeId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Templates are publicly readable but only admin writable.
     * @path /databases/{database}/documents/templates/{templateId}
     * @allow (get, list) Any user can read templates.
     * @deny (create, update, delete) No user can create, update, or delete templates.
     * @principle Templates are public read, admin only write.
     */
    match /templates/{templateId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Public resumes are publicly readable. Only the owner can update/delete.
     * @path /databases/{database}/documents/publicResumes/{shareId}
     * @allow (get, list) Any user can read public resumes.
     * @allow (create, update, delete) Only the owner can create, update or delete public resumes.
     * @principle Public resumes are public read, owner only write.
     */
    match /publicResumes/{shareId} {
        function isOwner() {
            return request.auth != null && request.auth.uid == resource.data.ownerId;
        }

      allow get, list: if true;
       // CRITICAL: Cannot implement owner-only writes. The 'Recipe' entity is missing an 'ownerId' or 'authorId' field.
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    /**
     * @description Feedback on public resumes is publicly creatable.
     * @path /databases/{database}/documents/publicResumes/{shareId}/feedback/{feedbackId}
     * @allow create Any user can create feedback.
     * @deny update, delete No user can update or delete feedback.
     * @principle Public creation, no modification.
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow get, list: if true;
      allow update, delete: if false;
    }
  }
}