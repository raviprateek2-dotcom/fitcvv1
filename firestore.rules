/**
 * @fileoverview Firestore Security Rules for Resume Builder App
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and resumes,
 * while allowing public read access to templates and shared resumes.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, owned by the user.
 * - /users/{userId}/resumes/{resumeId}: Resumes, owned by the user.
 * - /templates/{templateId}: Public resume templates, globally accessible.
 * - /publicResumes/{shareId}: Public, shareable resumes.
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Feedback comments on shared resumes.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profiles and resumes.
 * - Templates are publicly readable but not writable by users.
 * - Shared resumes are publicly readable, but feedback is open to all (no auth check).
 * - User listing is disallowed.
 *
 * Denormalization for Authorization:
 * - Resumes denormalize the `userId` to simplify ownership checks in subcollections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects the top-level /users collection, ensuring users can only access their own profile.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user_abc' can create their own profile document at /users/user_abc.
     * @allow (get) - User with UID 'user_abc' can read their own profile document at /users/user_abc.
     * @allow (update) - User with UID 'user_abc' can update their own profile document at /users/user_abc.
     * @allow (delete) - User with UID 'user_abc' can delete their own profile document at /users/user_abc.
     * @deny (create) - User with UID 'user_xyz' cannot create a profile document at /users/user_abc (mismatched UID).
     * @deny (get) - User with UID 'user_xyz' cannot read the profile document at /users/user_abc (mismatched UID).
     * @deny (update) - User with UID 'user_xyz' cannot update the profile document at /users/user_abc (mismatched UID).
     * @deny (delete) - User with UID 'user_xyz' cannot delete the profile document at /users/user_abc (mismatched UID).
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.email is string;
      allow update: if isExistingOwner(userId) && request.resource.data.email is string;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Protects the /users/{userId}/resumes collection, ensuring users can only access their own resumes.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) - User with UID 'user_abc' can create a resume document at /users/user_abc/resumes/resume1.
     * @allow (get) - User with UID 'user_abc' can read their own resume document at /users/user_abc/resumes/resume1.
     * @allow (update) - User with UID 'user_abc' can update their own resume document at /users/user_abc/resumes/resume1.
     * @allow (delete) - User with UID 'user_abc' can delete their own resume document at /users/user_abc/resumes/resume1.
     * @deny (create) - User with UID 'user_xyz' cannot create a resume document at /users/user_abc/resumes/resume1 (mismatched UID).
     * @deny (get) - User with UID 'user_xyz' cannot read the resume document at /users/user_abc/resumes/resume1 (mismatched UID).
     * @deny (update) - User with UID 'user_xyz' cannot update the resume document at /users/user_abc/resumes/resume1 (mismatched UID).
     * @deny (delete) - User with UID 'user_xyz' cannot delete the resume document at /users/user_abc/resumes/resume1 (mismatched UID).
     * @principle Enforces document ownership for all operations on resumes.
     */
    match /users/{userId}/resumes/{resumeId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && resource.data.userId == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to templates, but restricts writes.
     * @path /templates/{templateId}
     * @allow (get) - Any user can read template data at /templates/template1.
     * @allow (list) - Any user can list templates at /templates.
     * @deny (create) - No user can create templates.
     * @deny (update) - No user can update templates.
     * @deny (delete) - No user can delete templates.
     * @principle Templates are read-only for all users.
     */
    match /templates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

        /**
         * @description Allows public read access to shared resumes, but restricts writes.
         * @path /publicResumes/{shareId}
         * @allow (get) - Any user can read a shared resume at /publicResumes/share123.
         * @allow (list) - Any user can list shared resumes (potentially dangerous).
         * @deny (create) - No user can create a shared resume directly (must be created via /users/{userId}/resumes/{resumeId}).
         * @deny (update) - No user can update a shared resume directly.
         * @deny (delete) - No user can delete a shared resume directly.
         * @principle Shared resumes are read-only for all users.
         */
        match /publicResumes/{shareId} {
            allow get: if true;
            allow list: if true;
            allow create: if false;
            allow update: if false;
            allow delete: if false;
        }

        /**
         * @description Allows anyone to create feedback on shared resumes.
         * @path /publicResumes/{shareId}/feedback/{feedbackId}
         * @allow (create) - Any user, even unauthenticated, can create feedback.
         * @allow (get) - Any user can read feedback.
         * @allow (list) - Any user can list feedback (potentially noisy, but allowed).
         * @deny (update) - No user can update feedback.
         * @deny (delete) - No user can delete feedback.
         * @principle Feedback is publicly accessible.
         */
        match /publicResumes/{shareId}/feedback/{feedbackId} {
            allow get: if true;
            allow list: if true;
            allow create: if true;
            allow update: if false;
            allow delete: if false;
        }


    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}