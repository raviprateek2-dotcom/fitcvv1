rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Utility function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Match users collection
    match /users/{userId} {
      // Only allow read/write access if the user ID matches the authenticated user's ID
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Match resumes collection
    match /users/{userId}/resumes/{resumeId} {
      // Only allow read/write access if the user ID matches the authenticated user's ID
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Match templates collection
    match /templates/{templateId} {
      // Allow anyone to read templates
      allow read: if true;
      // No one can create or update templates through the client
      allow create, update, delete: if false;
    }

    // Match publicResumes collection
    match /publicResumes/{shareId} {
      // Allow anyone to read shared resumes
      allow read: if true;
      allow write: if false;

       // Match feedback collection on shared resumes
       match /feedback/{feedbackId} {
          // Allow anyone to create feedback
          allow create: if true;
          allow read, update, delete: if false;
        }
    }

    // Disallow listing all users
    match /users {
      allow get: if false;
    }
  }
}