/**
 * @fileoverview Firestore Security Rules for Resume App
 *
 * Core Philosophy:
 * This ruleset implements a combination of ownership-based and public-read access patterns. User-generated content (resumes) is protected by owner-only access. Templates are globally readable. Shared resumes are publicly readable but writable only by the owner.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only by the user.
 * - /users/{userId}/resumes/{resumeId}: Stores user resumes, accessible only by the user.
 * - /templates/{templateId}: Stores resume templates, publicly readable.
 * - /publicResumes/{shareId}: Stores shared resumes, publicly readable, owner-only writable.
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Stores feedback for shared resumes, publicly writable.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect user privacy.
 * - Templates are publicly readable to allow easy access to available templates.
 * - Public resumes can be written by the owner to update them.
 *
 * Denormalization for Authorization:
 * The 'Resume' entity contains a 'userId' property, which is used to enforce ownership in the
 * /users/{userId}/resumes/{resumeId} path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId The user ID to compare against the request's auth UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the resource.
     * @param {string} userId The user ID to compare against the request's auth UID.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces that the user ID in the path matches the user ID in the request.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' creates their profile at /users/user123.
     * @deny (create) User with UID 'user123' attempts to create profile at /users/user456.
     * @principle Enforces user-ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces that only the owner can manage their resumes.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (create) User 'user123' creates a resume under their profile.
     * @deny (update) User 'user456' attempts to update a resume owned by 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/resumes/{resumeId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows anyone to read resume templates, but no one to create, update, or delete.
     * @path /templates/{templateId}
     * @allow (get) Any user can retrieve a template.
     * @deny (create) No one can create a new template.
     * @principle Provides public read access to templates.
     */
    match /templates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read shared resumes, but only the owner to update or delete them.
     * @path /publicResumes/{shareId}
     * @allow (get) Any user can retrieve a shared resume.
     * @allow (update) The owner of the resume can update it.
     * @deny (update) A non-owner attempts to update a shared resume.
     * @principle Public read access with owner-only writes.
     */
    match /publicResumes/{shareId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(resource.data.id);
      allow delete: if isExistingOwner(resource.data.id);
    }

    /**
     * @description Allows anyone to submit feedback for a shared resume.
     * @path /publicResumes/{shareId}/feedback/{feedbackId}
     * @allow (create) Any user can create feedback for a shared resume.
     * @deny (update) No one can update feedback (feedback is immutable).
     * @principle Allows public write access to feedback.
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
      allow get: if true;
      allow list: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }
  }
}