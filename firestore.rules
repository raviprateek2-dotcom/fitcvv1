/**
 * @fileoverview Firestore Security Rules for Resume App
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and resumes,
 * while allowing public read access to templates and shared resumes.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, owned by the user.
 * - /users/{userId}/resumes/{resumeId}: Resumes owned by the user.
 * - /templates/{templateId}: Public resume templates.
 * - /publicResumes/{shareId}: Publicly shared resumes.
 * - /publicResumes/{shareId}/feedback/{feedbackId}: Feedback on public resumes.
 *
 * Key Security Decisions:
 * - Users can only access their own profiles and resumes.
 * - Templates are publicly readable but not writable by clients.
 * - Public resumes are publicly readable.
 * - Listing of user documents is allowed for the owner.
 *
 * Denormalization for Authorization:
 *  - Ownership is enforced via path-based rules (e.g., /users/{userId}). The `userId`
 *    is implicitly denormalized into the resume document by its location under
 *    the `/users/{userId}` path.
 *
 * Structural Segregation:
 * - Public and private resumes are stored in separate collections (/users/{userId}/resumes
 *   vs. /publicResumes/{shareId}) to avoid needing a boolean flag and to optimize
 *   list operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own user profile.
     * @path /databases/{database}/documents/users/{userId}
     * @allow (get, create, update, delete): if request.auth.uid == userId
     * @deny (get, create, update, delete): if request.auth.uid != userId
     * @principle Enforces document ownership for all operations on user profiles.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows users to manage their own resumes.
     * @path /databases/{database}/documents/users/{userId}/resumes/{resumeId}
     * @allow (get, list, create): if request.auth.uid == userId
     * @allow (update, delete): if request.auth.uid == userId && resource != null
     * @deny (get, list, create, update, delete): if request.auth.uid != userId
     * @principle Enforces document ownership for all operations on resumes.
     */
    match /users/{userId}/resumes/{resumeId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to resume templates, but restricts write access.
     * @path /databases/{database}/documents/templates/{templateId}
     * @allow (get, list): if true
     * @deny (create, update, delete): if true
     * @principle Templates are globally accessible for reading.
     */
    match /templates/{templateId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public read access to shared resumes.
     * @path /databases/{database}/documents/publicResumes/{shareId}
     * @allow get: if true
     * @deny list: if true
     * @allow list: if false;
     * @deny create, update, delete: if true
     * @principle Public resumes are globally accessible for reading, but not for modification.
     */
     match /publicResumes/{shareId} {
        allow get: if true;
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Allows anyone to create feedback on public shared resumes, but only read access.
     * @path /databases/{database}/documents/publicResumes/{shareId}/feedback/{feedbackId}
     * @allow get: if true
     * @allow list: if true
     * @deny create, update, delete: if true
     * @principle Public resumes can receive feedback from anyone, but only through the create function.
     */
    match /publicResumes/{shareId}/feedback/{feedbackId} {
        allow get: if true;
        allow list: if true;
        allow create: if true; // Allowing anyone to create feedback
        allow update: if false;
        allow delete: if false;
    }
  }
}