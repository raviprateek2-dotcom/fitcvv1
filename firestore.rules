rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects user profiles, ensuring only the owner can read and write their own profile data.
     * @path /users/{userId}
     * @allow (get, create, update, delete) if the authenticated user's UID matches the `userId` path segment.
     * @deny (get, create, update, delete) if the authenticated user's UID does not match the `userId` path segment.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if request.auth.uid == userId;
      allow list: if false;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    /**
     * @description Protects resumes, ensuring only the owner can read, write, and delete their own resumes.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (get, create, update, delete) if the authenticated user's UID matches the `userId` path segment.
     * @deny (get, create, update, delete) if the authenticated user's UID does not match the `userId` path segment.
     * @principle Restricts access to a user's own resume data tree.
     */
    match /users/{userId}/resumes/{resumeId} {
      allow get: if request.auth.uid == userId;
      allow list: if false;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    /**
     * @description Makes resume templates publicly accessible.
     * @path /templates/{templateId}
     * @allow (get, list) to anyone.
     * @deny (create, update, delete) to everyone.
     * @principle Allows public read access while restricting write access.
     */
    match /templates/{templateId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
      /**
       * @description Allows public read access to shared resumes. Writes are forbidden
       * @path /publicResumes/{shareId}
       * @allow get, list: to anyone.
       * @deny create, update, delete: to everyone.
       * @principle Allows public read access to shared resume.
       */
      match /publicResumes/{shareId} {
          allow get, list: if true;
          allow create, update, delete: if false;
      }

      /**
       * @description Allows public read and write access to feedback on shared resumes.
       * @path /publicResumes/{shareId}/feedback/{feedbackId}
       * @allow get, list, create, update, delete: to anyone.
       * @principle Allows public feedback on shared resumes.
       */
      match /publicResumes/{shareId}/feedback/{feedbackId} {
          allow get, list, create, update, delete: if true;
      }
  }
}